{
  "name": "sapid-weighing-system",
  "version": "1.0.0",
  "description": "Sistema Automatizado de Pesaje e Integración Digital",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && tsx watch src/index.ts",
    "dev:frontend": "cd frontend && next dev -p 3000",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && tsc",
    "build:frontend": "cd frontend && next build",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && node dist/index.js",
    "start:frontend": "cd frontend && next start -p 3000",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && vitest run",
    "test:frontend": "cd frontend && vitest run",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && eslint src --ext .ts",
    "lint:frontend": "cd frontend && next lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:init": "cd backend && tsx src/database/init.ts",
    "db:migrate": "cd backend && tsx src/database/migrate.ts",
    "db:seed": "cd backend && tsx src/database/seed.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.1.1",
    "@vitest/coverage-v8": "^1.1.1",
    "fast-check": "^3.15.0",
    "concurrently": "^8.2.2",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
