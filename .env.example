# Environment Configuration
NODE_ENV=development

# Backend Configuration
BACKEND_PORT=3001

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sapid
DB_USER=sapid_user
DB_PASSWORD=sapid123

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=8h

# Scale Configuration
# Protocol: RS232 or TCP
SCALE_PROTOCOL=RS232
# For RS232: Serial port path (e.g., /dev/ttyUSB0 on Linux, COM3 on Windows)
SCALE_PORT=/dev/ttyUSB0
# For TCP: Host and port
SCALE_HOST=192.168.1.100
SCALE_TCP_PORT=8080
# Serial configuration
SCALE_BAUD_RATE=9600
SCALE_DATA_BITS=8
SCALE_STOP_BITS=1
SCALE_PARITY=none
# Timeout in milliseconds
SCALE_TIMEOUT=2000
# Manufacturer (for parser selection)
SCALE_MANUFACTURER=generic

# Printer Configuration
# Type: network, usb, or serial
PRINTER_TYPE=network
# For network: IP address
# For USB: USB device path
# For serial: Serial port path
PRINTER_INTERFACE=192.168.1.200
# Printer width in characters (typically 48 for 80mm)
PRINTER_WIDTH=48
# Encoding (cp437, utf8, etc.)
PRINTER_ENCODING=cp437

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/sapid.log

# Security Configuration
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5
